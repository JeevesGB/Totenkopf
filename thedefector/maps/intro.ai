//PLAYER
player 
{
	playerstart 
	{
		mu_start sound/music/m_assault
		print The Defector
	}

	spawn
	{
		mu_start sound/music/l_theme
	}

	trigger musickill
	{
		mu_stop 
	}
}

// SOLDIERS
	//walking out of spawn room 
soldier1
{
	attributes
	{
		fov 90
		hearing_scale 0.0
	}

	spawn
	{
		wait 1000
		trigger soldier1 walking
	}

	trigger walking
	{
		walktomarker marker1
		walktomarker marker2
		trigger soldier1 walking
	}

	enemysight
	{
		resetscript
	}
}

